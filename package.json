{
  "name": "schrutefacts",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @schrutefacts/db db:push",
    "db:studio": "turbo -F @schrutefacts/db db:studio",
    "db:generate": "turbo -F @schrutefacts/db db:generate",
    "db:migrate": "turbo -F @schrutefacts/db db:migrate",
    "db:start": "docker compose up -d postgres",
    "db:watch": "docker compose up postgres",
    "db:stop": "docker compose stop postgres",
    "db:down": "docker compose down postgres",
    "db:clean": "docker compose stop postgres && rm -rf .data/postgres",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:clean": "docker compose down && rm -rf .data/postgres",
    "docker:logs": "docker compose logs -f",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@schrutefacts/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@schrutefacts/config": "workspace:*",
    "@types/node": "22.13.14",
    "@xarc/run": "2.3.0",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "turbo": "2.9.16",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.24.0"
}
